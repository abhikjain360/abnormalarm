<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="18dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextClock
        android:id="@+id/widget_main_clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:format12Hour="HH:mm"
        android:format24Hour="HH:mm"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="#FFEAF0FF"
        android:textSize="78sp" />

    <LinearLayout
        android:id="@+id/widget_status_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextClock
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEE, d MMM"
            android:format24Hour="EEE, d MMM"
            android:includeFontPadding="false"
            android:textColor="#FFEAF0FF"
            android:textSize="24sp" />

        <ImageView
            android:id="@+id/widget_alarm_icon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/widget_next_alarm_label"
            android:src="@drawable/ic_alarm"
            android:tint="#FFEAF0FF" />

        <TextView
            android:id="@+id/widget_next_alarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="#FFEAF0FF"
            android:textSize="24sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_zones_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_zone_one"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextClock
                android:id="@+id/widget_zone_one_clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="#FFEAF0FF"
                android:textSize="38sp" />

            <TextView
                android:id="@+id/widget_zone_one_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#FFEAF0FF"
                android:textSize="18sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_zone_gap"
            android:layout_width="22dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/widget_zone_two"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextClock
                android:id="@+id/widget_zone_two_clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="#FFEAF0FF"
                android:textSize="38sp" />

            <TextView
                android:id="@+id/widget_zone_two_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#FFEAF0FF"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
